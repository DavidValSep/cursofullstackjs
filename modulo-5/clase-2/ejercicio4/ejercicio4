DROP TABLE IF EXISTS serie_netflix;
CREATE TABLE serie_netflix
(
    nombre character varying NOT NULL,
    temporadas integer,
    genero character varying(50),
    anio_estreno integer,
    PRIMARY KEY (nombre)
);

